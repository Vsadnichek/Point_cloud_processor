<launch>

  <!-- Аргументы -->
  <arg name="calibration" default="$(find velodyne_pointcloud)/params/VLP16db.yaml"/>
  <arg name="device_ip" default="" />
  <arg name="frame_id" default="velodyne" />
  <arg name="pcap" default="" />
  <arg name="port" default="2368" />
  <arg name="rpm" default="600.0" />
  <arg name="min_range" default="0.4" />
  <arg name="max_range" default="130.0" />
  <arg name="organize_cloud" default="false" />

  <!-- Драйвер Velodyne (nodelet-менеджер + трансформер) -->
  <include file="$(find velodyne_pointcloud)/launch/VLP16_points.launch">
    <arg name="calibration" value="$(arg calibration)" />
    <arg name="device_ip" value="$(arg device_ip)" />
    <arg name="frame_id" value="$(arg frame_id)" />
    <arg name="pcap" value="$(arg pcap)" />
    <arg name="port" value="$(arg port)" />
    <arg name="rpm" value="$(arg rpm)" />
    <arg name="min_range" value="$(arg min_range)" />
    <arg name="max_range" value="$(arg max_range)" />
    <arg name="organize_cloud" value="$(arg organize_cloud)" />
  </include>

  <!-- Нода зеркального отражения -->
  <node pkg="mirror_live_node"
      type="mirror_reflector_node.py"
      name="mirror_reflector_node"
      output="screen">
      <param name="x" value="0.0" />
      <param name="y" value="0.306" />
      <param name="yaw" value="31.6" />
</node>

  <!-- GUI для динамической настройки зеркала -->
<!--
  <node pkg="rqt_reconfigure"
      type="rqt_reconfigure"
      name="mirror_params_gui"
      output="screen"/>
-->

  <node type="rviz" name="rviz" pkg="rviz" args="-d $(find mirror_live_node)/rviz/two_clouds.rviz" />

</launch>
