<?xml version="1.0"?>
<launch>
    <!-- Аргументы для удобного переопределения при запуске -->
    <arg name="input_topic"                  default="/livox/lidar"/>
    <arg name="output_dense_topic"           default="/dense_cloud"/>
    <arg name="output_objects_topic"         default="/points_filtered"/>
    <arg name="output_plane_topic"           default="/points_plane"/>
    <arg name="accumulation_frames"          default="50"/>
    <arg name="voxel_leaf_size"              default="0.3"/>
    <arg name="ransac_distance_threshold"    default="0.02"/>
    <arg name="ransac_accumulation_frames"   default="4"/>
    <arg name="ransac_max_iterations"        default="1000"/>
    <arg name="ransac_min_plane_points"      default="500"/>
    <arg name="ransac_min_inlier_ratio"      default="0.05"/>

    <!-- Нода -->
    <node name="PointCloudFilter" pkg="pointcloud_processor" type="pointcloud_filter.py" output="screen">
        <!-- Приватные параметры ноды (читаются через ~) -->
        <param name="input_topic"                   value="$(arg input_topic)"/>
        <param name="output_dense_topic"            value="$(arg output_dense_topic)"/>
        <param name="output_objects_topic"          value="$(arg output_objects_topic)"/>
        <param name="output_plane_topic"            value="$(arg output_plane_topic)"/>
        <param name="accumulation_frames"           value="$(arg accumulation_frames)"/>
        <param name="voxel_leaf_size"               value="$(arg voxel_leaf_size)"/>
        <param name="ransac_distance_threshold"     value="$(arg ransac_distance_threshold)"/>
        <param name="ransac_accumulation_frames"    value="$(arg ransac_accumulation_frames)"/>
        <param name="ransac_max_iterations"         value="$(arg ransac_max_iterations)"/>
        <param name="ransac_min_plane_points"       value="$(arg ransac_min_plane_points)"/>
        <param name="ransac_min_inlier_ratio"       value="$(arg ransac_min_inlier_ratio)"/>
    </node>
</launch>